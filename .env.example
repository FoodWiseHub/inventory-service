PORT=3003
SERVICE_NAME=inventory-service
DATABASE_URL=

# The gateway must send this token in x-internal-service-token.
ALLOWED_GATEWAY_TOKEN_CURRENT=
ALLOWED_GATEWAY_TOKEN_PREVIOUS=

SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_INVENTORY_PHOTOS_BUCKET=inventory-item-photos

# Gateway configuration examples:
# Local development outside Docker:
# INVENTORY_SERVICE_URL=http://localhost:3003
#
# Docker Compose:
# INVENTORY_SERVICE_URL=http://inventory-service:3003
